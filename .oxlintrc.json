{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    ".claude/**",
    ".cline/**",
    ".cursor/**",
    ".expo/**",
    ".github/skills/**",
    "_bmad/**",
    "_bmad-output/**",
    "android/**",
    "coverage/**",
    "design-artifacts/**",
    "dist/**",
    "docs/**",
    "ios/**",
    "node_modules/**",
    "apps/mobile/scripts/reset-project.js"
  ],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  }
}
