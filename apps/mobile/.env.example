# Mobile environment variables
#
# Expo only inlines variables prefixed with EXPO_PUBLIC_ at bundle time.
# Restart the Metro bundler after editing this file.

# Base URL of the One Down backend (apps/server). The mobile tRPC client
# resolves this at startup and falls back to http://localhost:3000 when unset.
#
# Platform tips:
# - iOS simulator      → http://localhost:3000
# - Android emulator   → http://10.0.2.2:3000   (10.0.2.2 is the host loopback)
# - Physical device    → http://<your-LAN-IP>:3000  (e.g. http://192.168.1.42:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
